DB_HOST=localhost
DB_USER=root
DB_PASSWORD=123456
DB_NAME=traffic
PORT=3001
DB_PORT=3306


REDIS_HOST=localhost
REDIS_PORT=6379
AUTH_DEV_LOG_CODES=true
AUTH_CAPTCHA_RATE_SECONDS=2
TRAFFIC_REAL_TABLE=traffic_flow
TRAFFIC_MOCK_TABLE=traffic_flow_mock

